# Auto-detect text files and normalise to LF on commit.
* text=auto

# Python — always LF (shebangs break with CRLF on Linux).
*.py text eol=lf

# TypeScript / JavaScript / JSON — LF.
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf

# Markdown / YAML — LF.
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Shell scripts — LF (CRLF breaks them on all Unix systems).
*.sh text eol=lf

# Windows-specific — keep CRLF.
*.bat text eol=crlf
*.ps1 text eol=crlf
*.cmd text eol=crlf

# Binary files — never convert.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.whl binary
